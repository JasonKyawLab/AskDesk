# AskDesk configuration — copy to .env and fill in for local development.
# Never commit .env (it is gitignored).

# Deployment environment: development | production
ASKDESK_ENV=development

# Port the web tier listens on
ASKDESK_HTTP_PORT=8080

# Log level: debug | info | warn | error
ASKDESK_LOG_LEVEL=info

# Postgres DSN (matches docker-compose; host port 5433). Leave empty to run without a database.
ASKDESK_DATABASE_URL=postgres://askdesk:askdesk@localhost:5433/askdesk?sslmode=disable

# The business this instance serves (Phase 1 is single-tenant).
ASKDESK_BUSINESS_ID=1

# Gemini API key (ai.google.dev). Empty falls back to a static dev provider.
ASKDESK_GEMINI_API_KEY=
# Optional model overrides (set if the defaults are deprecated).
# Defaults: gemini-3.5-flash (generation), gemini-embedding-001 (768-dim embeddings).
# ASKDESK_GEMINI_GEN_MODEL=
# ASKDESK_GEMINI_EMBED_MODEL=

# Redis URL for the task queue (matches docker-compose; host port 6380).
# Required when the Telegram webhook is enabled.
ASKDESK_REDIS_URL=redis://localhost:6380/0

# Telegram bot (from @BotFather). Empty disables the Telegram webhook.
ASKDESK_TELEGRAM_BOT_TOKEN=
# Secret token verified on every Telegram webhook request.
ASKDESK_TELEGRAM_WEBHOOK_SECRET=

# Magic-link FAQ editor. Empty disables it. Secret signs edit links/sessions;
# PUBLIC_URL is the externally reachable base URL used to build the links.
ASKDESK_MAGIC_LINK_SECRET=
ASKDESK_PUBLIC_URL=http://localhost:8080

# Shop name, welcome message, fallback message, and "ask" prompt are per-business
# settings edited at runtime on the /edit page — no env var / redeploy needed.

# Web API (/api/v1/*): comma-separated allowed CORS origins. "*" allows any.
# e.g. https://minipos.site  (only needed if a browser calls the API directly)
ASKDESK_CORS_ORIGINS=*
