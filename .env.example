# AskDesk configuration — copy to .env and fill in for local development.
# Never commit .env (it is gitignored).

# Deployment environment: development | production
ASKDESK_ENV=development

# Port the web tier listens on
ASKDESK_HTTP_PORT=8080

# Log level: debug | info | warn | error
ASKDESK_LOG_LEVEL=info

# --- Added as features land ---
# ASKDESK_DATABASE_URL=postgres://user:pass@localhost:5432/askdesk?sslmode=disable
# ASKDESK_REDIS_URL=redis://localhost:6379/0
# ASKDESK_TELEGRAM_WEBHOOK_SECRET=
# ASKDESK_GEMINI_API_KEY=
